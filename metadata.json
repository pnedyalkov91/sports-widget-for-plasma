        "Authors": [
            {
                "Name": "Petar Nedyalkov",
                "Email": "petar.nedyalkov91@gmail.com",
                "Role": "Author, design and development"
            }
        ],
        "Version": "1.0.0",
        "Website": "https://github.com/pnedyalkov91/sports-widget-for-plasma",
        "BugReportUrl": "https://github.com/pnedyalkov91/sports-widget-for-plasma/issues"
    },
    "X-Plasma-API-Minimum-Version": "6.0",
