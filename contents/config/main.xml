<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
      http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
  <kcfgfile name=""/>

  <group name="General">
    <entry name="provider" type="String">
      <default>sportscore</default>
    </entry>
    <entry name="defaultSport" type="String">
      <default>football</default>
    </entry>
    <entry name="selectedSports" type="String">
      <default></default>
    </entry>
    <entry name="country" type="String">
      <default></default>
    </entry>
    <entry name="league" type="String">
      <default></default>
    </entry>
    <entry name="favoriteTeam" type="String">
      <default></default>
    </entry>
    <entry name="savedLeagues" type="String">
      <default>[]</default>
    </entry>
    <entry name="defaultSelectionMigrated" type="Bool">
      <default>false</default>
    </entry>
    <entry name="selectionRevision" type="Int">
      <default>0</default>
    </entry>
    <entry name="activeSavedLeagueIndex" type="Int">
      <default>0</default>
    </entry>
    <entry name="smartRefreshEnabled" type="Bool">
      <default>true</default>
    </entry>
    <entry name="refreshInterval" type="Int">
      <default>30</default>
      <min>1</min>
      <max>1440</max>
    </entry>
    <entry name="liveRefreshEnabled" type="Bool">
      <default>true</default>
    </entry>
    <entry name="liveRefreshInterval" type="Int">
      <default>60</default>
      <min>10</min>
      <max>300</max>
    </entry>
    <entry name="nationalTeamVisualStyle" type="String">
      <default>emblems</default>
    </entry>
    <!-- Panel presentation: "detailed" shows the match (teams/score/badges,
         per panelLayoutMode), "simple" shows only a compact count of live and
         remaining matches with the sport icon (GNOME Colosseum style). -->
    <entry name="panelMode" type="String">
      <default>detailed</default>
    </entry>
    <!-- Simple-mode count format: "remaining" -> "N" (remaining games only);
         "liveRemaining" -> "A / B" (live games / remaining games). -->
    <entry name="panelCountsFormat" type="String">
      <default>liveRemaining</default>
    </entry>
    <!-- Which scheduled matches the simple panel mode counts as "remaining":
         "next24h" -> kickoff within the next 24 hours; "all" -> every upcoming
         fixture in the panel scope. -->
    <entry name="panelSimpleScheduleWindow" type="String">
      <default>next24h</default>
    </entry>
    <entry name="panelLayoutMode" type="String">
      <default>teamsAndBadges</default>
    </entry>
    <entry name="panelAreaMode" type="String">
      <default>auto</default>
    </entry>
    <entry name="panelAreaSize" type="Int">
      <default>240</default>
      <min>20</min>
      <max>1000</max>
    </entry>
    <entry name="panelUseSystemFont" type="Bool">
      <default>true</default>
    </entry>
    <entry name="panelFontFamily" type="String">
      <default></default>
    </entry>
    <entry name="panelFontSize" type="Int">
      <default>0</default>
      <min>0</min>
      <max>72</max>
    </entry>
    <entry name="panelFontBold" type="Bool">
      <default>false</default>
    </entry>
    <entry name="panelEmblemSize" type="Int">
      <default>0</default>
      <min>0</min>
      <max>64</max>
    </entry>
    <entry name="panelMatchRotationEnabled" type="Bool">
      <default>true</default>
    </entry>
    <entry name="panelMatchRotationInterval" type="Int">
      <default>30</default>
      <min>5</min>
      <max>300</max>
    </entry>
    <!-- How the panel shows multiple live/upcoming matches: "rotate" cycles one
         at a time (default), "stack" shows several side by side (Colosseum
         style), capped by panelStackMaxMatches. -->
    <entry name="panelMultiMatchMode" type="String">
      <default>rotate</default>
    </entry>
    <entry name="panelStackMaxMatches" type="Int">
      <default>3</default>
      <min>2</min>
      <max>8</max>
    </entry>
    <entry name="widgetMatchRotationEnabled" type="Bool">
      <default>true</default>
    </entry>
    <entry name="widgetMatchRotationInterval" type="Int">
      <default>30</default>
      <min>5</min>
      <max>300</max>
    </entry>
    <entry name="matchDateFormat" type="String">
      <default>dd.MM.yy</default>
    </entry>
    <entry name="matchTimeFormat" type="String">
      <default>HH:mm</default>
    </entry>
    <entry name="widgetLayoutMode" type="String">
      <default>detailed</default>
    </entry>
    <!-- Which scheduled matches the Simple widget layout lists alongside live
         ones: "all" -> every upcoming fixture; "next24h" -> only those with a
         kickoff within the next 24 hours. -->
    <entry name="widgetSimpleScheduleWindow" type="String">
      <default>all</default>
    </entry>
    <!-- Show the featured match ("hero") above the tabs in the Detailed layout. -->
    <entry name="widgetHeroEnabled" type="Bool">
      <default>true</default>
    </entry>
    <!-- Where the tab bar sits in the Detailed layout: "top" (above the tab
         content) or "bottom" (below it). -->
    <entry name="widgetTabsPosition" type="String">
      <default>top</default>
    </entry>
    <!-- Legacy tab-visibility preset (all/liveStats/liveTables/liveOnly). Kept so
         existing setups migrate to the per-tab switches below; no longer written
         by the settings UI. -->
    <entry name="widgetTabs" type="String">
      <default>all</default>
    </entry>
    <!-- Per-tab visibility switches ("Visible tabs"). Live and Schedules are the
         core tabs; Recent Results and Tables can be hidden individually. Tables
         is additionally hidden automatically for sports without standings. -->
    <entry name="showTabLive" type="Bool">
      <default>true</default>
    </entry>
    <entry name="showTabSchedules" type="Bool">
      <default>true</default>
    </entry>
    <entry name="showTabRecent" type="Bool">
      <default>true</default>
    </entry>
    <entry name="showTabTables" type="Bool">
      <default>true</default>
    </entry>
    <!-- Show the one-click bell / star / pin action icons on each match row. -->
    <entry name="showMatchRowActions" type="Bool">
      <default>true</default>
    </entry>
    <!-- How many recent matches to show per team/competition group in the
         Recent Results tab. -->
    <entry name="widgetRecentMatchesPerGroup" type="Int">
      <default>5</default>
      <min>1</min>
      <max>30</max>
    </entry>
    <!-- Which saved-entry types to show in the Recent Results tab:
         "both", "teams" or "competitions". -->
    <entry name="widgetRecentFilter" type="String">
      <default>both</default>
    </entry>
    <!-- How far ahead (days) to look for upcoming fixtures in the Schedules tab. -->
    <entry name="widgetScheduleDaysAhead" type="Int">
      <default>150</default>
      <min>1</min>
      <max>365</max>
    </entry>
    <!-- How many upcoming matches to show per team/competition group in the
         Schedules tab. -->
    <entry name="widgetScheduleMatchesPerGroup" type="Int">
      <default>5</default>
      <min>1</min>
      <max>30</max>
    </entry>
    <!-- How many live matches to list in the panel hover tooltip. -->
    <entry name="tooltipLiveMatchesLimit" type="Int">
      <default>5</default>
      <min>1</min>
      <max>30</max>
    </entry>
    <!-- How many days ahead to look for upcoming fixtures in the tooltip. -->
    <entry name="tooltipScheduleDaysAhead" type="Int">
      <default>1</default>
      <min>1</min>
      <max>5</max>
    </entry>
    <!-- How many days back to look for finished matches in the tooltip's
         Recent section. -->
    <entry name="tooltipRecentDaysBack" type="Int">
      <default>5</default>
      <min>1</min>
      <max>5</max>
    </entry>
    <entry name="prioritizePopular" type="Bool">
      <default>false</default>
    </entry>
    <entry name="notificationsEnabled" type="Bool">
      <default>false</default>
    </entry>
    <entry name="notifyKickoff" type="Bool">
      <default>true</default>
    </entry>
    <entry name="notifyGoals" type="Bool">
      <default>true</default>
    </entry>
    <entry name="notifyFullTime" type="Bool">
      <default>true</default>
    </entry>
    <entry name="notifyHalfTime" type="Bool">
      <default>true</default>
    </entry>
    <!-- Opt-in, off by default: polls each live football match's ESPN incident
         feed (goals/cards/subs) on a separate, slower timer so goal
         notifications can include the scorer and yellow/red cards and
         substitutions can be announced. Costs one extra request per live
         football match per poll; only matches sourced from ESPN are polled. -->
    <entry name="notifyDetailedEvents" type="Bool">
      <default>false</default>
    </entry>
    <entry name="notifyStartsSoon" type="Bool">
      <default>true</default>
    </entry>
    <entry name="notifyStartsSoonMinutes" type="Int">
      <default>15</default>
      <min>1</min>
      <max>180</max>
    </entry>
    <entry name="notifyFavoriteTeamsOnly" type="Bool">
      <default>false</default>
    </entry>
    <entry name="calendarSyncEnabled" type="Bool">
      <default>false</default>
    </entry>
    <!-- Optional: also write a plain iCalendar (.ics) EXPORT file the user can
         import/subscribe to in any calendar app. It is never registered as an
         Akonadi resource (that is what used to hang Plasma); it is just a file. -->
    <entry name="calendarIcsExportEnabled" type="Bool">
      <default>false</default>
    </entry>
    <!-- UNSTABLE / NOT RECOMMENDED: also register the .ics as a live Akonadi
         (KDE PIM) calendar resource. Can freeze plasmashell on some systems;
         opt-in only. Implies the .ics export. -->
    <entry name="calendarAkonadiEnabled" type="Bool">
      <default>false</default>
    </entry>
    <entry name="calendarReminderMinutes" type="Int">
      <default>15</default>
      <min>0</min>
      <max>1440</max>
    </entry>
    <entry name="notifyEntryInclusions" type="String">
      <default>[]</default>
    </entry>
    <entry name="calendarEntryInclusions" type="String">
      <default>[]</default>
    </entry>
    <!-- Per-match overrides set with the one-click row icons (bell / pin). Each
         is a JSON object keyed by a stable match key (league|home|away|day),
         mapping to true. Pruned automatically once a match has finished, so
         these never grow without bound. -->
    <entry name="perMatchNotify" type="String">
      <default>{}</default>
    </entry>
    <entry name="perMatchPanelPins" type="String">
      <default>{}</default>
    </entry>
    <!-- Teams favourited with the one-click row star. JSON object keyed by the
         normalized team name -> true. Lighter weight than a full saved-sports
         entry: it flags the team as favourite for ordering/highlighting and
         panel selection without changing the followed competitions. -->
    <entry name="quickFavoriteTeams" type="String">
      <default>{}</default>
    </entry>
  </group>
</kcfg>
